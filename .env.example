# Environment Variables Template
# Copy this file to .env and fill in your values
# Note: This project uses SSM Parameter Store for secrets in production
# These variables are only used for local development/testing

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Stripe Configuration (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=rk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Live Keys (for real $0.50 payments)
STRIPE_LIVE_SECRET_KEY=rk_live_...
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...

# Stripe Subscription Price IDs (from Stripe dashboard, test mode)
STRIPE_PRICE_REGISTERED_COMPLAINANT=price_...
STRIPE_PRICE_PRO_COMPLAINANT=price_...

# Session Configuration
SESSION_SECRET=your-random-secret-here

# Database Configuration
DATABASE_URL=postgresql://admin@your-dsql-endpoint:5432/postgres?sslmode=require

# Cognito Configuration (from CDK stack outputs)
COGNITO_USER_POOL_ID=us-east-1_...
COGNITO_CLIENT_ID=...

# Custom Domain (optional)
CUSTOM_DOMAIN=example.com

# Note: In production, these values are stored in AWS SSM Parameter Store at:
# - /grievance-portal/stripe/secret-key
# - /grievance-portal/stripe/publishable-key
# - /grievance-portal/stripe/webhook-secret
# - /grievance-portal/stripe/live-secret-key
# - /grievance-portal/stripe/live-publishable-key
# - /grievance-portal/stripe/price-registered-complainant
# - /grievance-portal/stripe/price-pro-complainant
# - /grievance-portal/session/secret
# - /grievance-portal/database/url
